<?xml version="1.0"?>
<ruleset name="DisableEmojis">
    <description>PSR-12 coding standards for Disable Emojis</description>

    <file>.</file>
    <exclude-pattern>vendor/</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="s"/>

    <rule ref="PSR12"/>
</ruleset>
